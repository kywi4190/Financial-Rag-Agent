# OpenAI API key for embeddings and LLM calls
OPENAI_API_KEY=sk-...

# SEC EDGAR requires a user-agent identity string (e.g., "Name email@example.com")
SEC_EDGAR_IDENTITY="Your Name your.email@example.com"

# ChromaDB persistence directory
CHROMA_PERSIST_DIR=.chroma

# Model configuration
EMBEDDING_MODEL=text-embedding-3-large
LLM_MODEL=gpt-4o

# Chunking parameters
CHUNK_SIZE=768
CHUNK_OVERLAP=128

# Retrieval parameters
TOP_K=10
RERANK_TOP_K=5
