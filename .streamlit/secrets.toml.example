# Streamlit Community Cloud secrets configuration
# Copy this to .streamlit/secrets.toml (local) or paste into the
# Streamlit Cloud dashboard under App Settings > Secrets.
#
# These values are exposed as st.secrets["KEY"] and also injected
# into the environment so python-dotenv / pydantic-settings can read them.

OPENAI_API_KEY = "sk-..."
SEC_EDGAR_IDENTITY = "YourName your@email.com"
